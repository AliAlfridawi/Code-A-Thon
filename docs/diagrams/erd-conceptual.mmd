erDiagram
  USER {
    uuid id PK
    string role
    string display_name
    string email
    datetime created_at
  }

  CLUB {
    uuid id PK
    string name
    string term
    datetime created_at
  }

  MENTEE_PROFILE {
    uuid id PK
    uuid user_id FK
    string major
    string graduation_year
    text goals_summary
    datetime updated_at
  }

  MENTOR_PROFILE {
    uuid id PK
    uuid user_id FK
    string expertise_areas
    string availability
    text mentoring_style
    datetime updated_at
  }

  OFFICER_PROFILE {
    uuid id PK
    uuid user_id FK
    uuid club_id FK
    string permissions
    datetime updated_at
  }

  PAIRING {
    uuid id PK
    uuid club_id FK
    uuid mentee_user_id FK
    uuid mentor_user_id FK
    uuid created_by_officer_user_id FK
    string status
    text match_reason
    datetime created_at
  }

  GOAL {
    uuid id PK
    uuid pairing_id FK
    string title
    string status
    date target_date
    datetime updated_at
  }

  CHECK_IN {
    uuid id PK
    uuid pairing_id FK
    datetime occurred_at
    bool meeting_occurred
    text mentee_reflection
    text mentor_feedback
  }

  MESSAGE {
    uuid id PK
    uuid pairing_id FK
    uuid sender_user_id FK
    string body
    datetime sent_at
  }

  SURVEY_RESPONSE {
    uuid id PK
    uuid check_in_id FK
    uuid respondent_user_id FK
    int satisfaction_score
    text comments
    datetime submitted_at
  }

  COMPATIBILITY_SCORE {
    uuid id PK
    uuid pairing_id FK
    int score
    float confidence
    text factors_json
    datetime calculated_at
  }

  ANALYTICS_SNAPSHOT {
    uuid id PK
    uuid club_id FK
    int meetings_count
    float avg_satisfaction
    float avg_compatibility
    datetime captured_at
  }

  USER ||--o| MENTEE_PROFILE : has
  USER ||--o| MENTOR_PROFILE : has
  USER ||--o| OFFICER_PROFILE : has

  CLUB ||--o{ OFFICER_PROFILE : includes
  CLUB ||--o{ PAIRING : manages
  CLUB ||--o{ ANALYTICS_SNAPSHOT : tracks

  USER ||--o{ PAIRING : mentee_in
  USER ||--o{ PAIRING : mentor_in
  USER ||--o{ PAIRING : created_by

  PAIRING ||--o{ GOAL : owns
  PAIRING ||--o{ CHECK_IN : records
  PAIRING ||--o{ MESSAGE : contains
  PAIRING ||--o{ COMPATIBILITY_SCORE : receives

  CHECK_IN ||--o{ SURVEY_RESPONSE : collects
  USER ||--o{ SURVEY_RESPONSE : submits
  USER ||--o{ MESSAGE : sends
