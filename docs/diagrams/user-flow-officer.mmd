flowchart TD
  Start([Enter Maventor]) --> Dashboard[Open Officer Dashboard]
  Dashboard --> ReviewProfiles[Review Mentor and Mentee Profiles]
  ReviewProfiles --> BuildPair[Create Manual Pairing]
  BuildPair --> ScoreHint[View Compatibility Score Hint]
  ScoreHint --> ConfirmPair{Approve pairing?}

  ConfirmPair -- No --> ReworkPair[Adjust mentor or mentee selection]
  ReworkPair --> BuildPair

  ConfirmPair -- Yes --> PairCreated[Pairing Activated]
  PairCreated --> MonitorMsgs[Monitor Messaging Activity]
  PairCreated --> MonitorCheckIns[Monitor Check-In Completion]
  PairCreated --> MonitorGoals[Monitor Goal Progress]

  MonitorMsgs --> Analytics[Open Analytics Dashboard]
  MonitorCheckIns --> Analytics
  MonitorGoals --> Analytics

  Analytics --> Decision{Intervention needed?}
  Decision -- Yes --> SupportAction[Trigger Follow-Up with Pair]
  SupportAction --> Analytics
  Decision -- No --> HealthyState[Pairing Healthy]
  HealthyState --> End([Continue Program Oversight])
